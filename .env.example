# ═══════════════════════════════════════════════════════════════════
# NEUROSCREEN ENVIRONMENT CONFIGURATION
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ═══ APPLICATION ENVIRONMENT ═══
# development, production, test
NODE_ENV=development

# Application base URL (used for redirects, CORS, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ═══ SUPABASE CONFIGURATION ═══
# From Supabase Console → Project Settings → API
# These are PUBLIC credentials (OK to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # SERVER-SIDE ONLY

# ═══ AI & LLM APIS (SERVER-SIDE ONLY) ═══
# From Anthropic → https://console.anthropic.com/account/keys
# DO NOT expose to browser - kept server-side only
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxx

# From Groq → https://console.groq.com/keys
# DO NOT expose to browser - kept server-side only
GROQ_API_KEY=gsk-xxxxxxxxxxxxxxxxxxxxx

# ═══ SECURITY ═══
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=your-random-secret-key-here-min-32-chars
PASSWORD_SALT=your-random-salt-here-min-32-chars

# ═══ DATABASE (OPTIONAL) ═══
# DATABASE_URL=postgresql://user:password@localhost:5432/neuroscreen

# ═══ FEATURE FLAGS ═══
# Enable/disable AI narrative reports (true/false)
ENABLE_AI_REPORTS=true

# Enable/disable cloud storage features (true/false)
ENABLE_CLOUD_STORAGE=false

# ═══ LOGGING ═══
# DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════
# SECURITY NOTICES:
# 1. API keys (ANTHROPIC_API_KEY, GROQ_API_KEY) are NEVER sent to browser
# 2. Variables prefixed with NEXT_PUBLIC_ are safe for client-side
# 3. All other variables are server-side only
# 4. .env.local is in .gitignore - never commit sensitive values
# 5. Use strong, random values for SECRET_KEY and PASSWORD_SALT
# ═══════════════════════════════════════════════════════════════════
